FROM golang:1.26 AS builder

WORKDIR /src

COPY go.mod go.sum ./
RUN go mod download

COPY . .

RUN CGO_ENABLED=0 GOOS=linux GOARCH=amd64 go build -o /out/prismaid-mcp ./cmd/prismaid-mcp

FROM gcr.io/distroless/static-debian12:nonroot

LABEL io.modelcontextprotocol.server.name="io.github.open-and-sustainable/prismaid-mcp"

COPY --from=builder /out/prismaid-mcp /usr/local/bin/prismaid-mcp

ENTRYPOINT ["/usr/local/bin/prismaid-mcp"]
